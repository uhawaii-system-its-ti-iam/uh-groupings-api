{
  "owner": "mhodges",
  "project": "groupings",
  "environment": "sandbox",
  "component": "api",

  "namingConvention": {
    "format": "<Owner>-<Project>-<Environment>-<Resource>",
    "example": "mhodges-groupings-sandbox-api",
    "description": "All AWS resources follow this pattern for consistency"
  },

  "deployment": {
    "awsRegion": "us-west-2",
    "sourceRepository": "uhawaii-system-its-ti-iam/uh-groupings-api",

    "pipeline": {
      "source": "github",
      "build": "codebuild",
      "deploy": "codepipeline"
    },

    "runtime": {
      "platform": "ecs-fargate"
    },

    "artifacts": {
      "containerImage": true
    }
  },

  "tags": {
    "Owner": "mhodges",
    "Project": "groupings",
    "Environment": "sandbox",
    "Component": "api",
    "ManagedBy": "CloudFormation"
  }
}