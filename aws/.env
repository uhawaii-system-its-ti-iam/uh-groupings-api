# aws/.env - Default non-secret configuration for aws/setup.sh
# - Loaded automatically by setup.sh when run from this directory (or via `make aws-setup`).
# - Keep secrets out of this file. The Grouper password lives in the developer's
#   overrides file (`~/.$USER-conf/uh-groupings-api-overrides.properties`); the
#   JWT signing key is generated by setup.sh. Both end up in AWS Secrets Manager.
# - Setup is non-interactive end to end: every value below must be set before
#   running `make aws-setup`, otherwise the script exits with an error.

# Required AWS deployment configuration
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=610572473041

# IAM Identity Center (SSO) configuration
# Used by `make aws-sso-setup` to write the AWS CLI profile non-interactively.
# These are not secrets — the start URL is a public portal endpoint.
# The SSO region is assumed to be AWS_REGION (above).
SSO_START_URL=https://d-9267e44193.awsapps.com/start
SSO_ROLE_NAME=AWSAdministratorAccess

# CloudFormation resource naming
#
# AWS_PROJECT_ID drives both the stack names (`${AWS_PROJECT_ID}-ecs-${AWS_ENV}`)
# and the CloudFormation `Project` parameter, which feeds into resource names
# such as `${AWS_OWNER}-${AWS_PROJECT_ID}-${AWS_ENV}-cluster`.
#
# AWS naming length limits — keep AWS_PROJECT_ID short.
#  - Application Load Balancer name: max 32 chars
#  - Target group name:              max 32 chars
#  - IAM role name:                  max 64 chars
#  - Most other resources:           max 255 chars
#
# Family of project ids (keep lengths < 14 characters):
#   - this project (Spring API):   groupings-api
#   - companion Angular UI:        groupings-aui
#   - companion React UI:          groupings-ui
#
AWS_ENV=sandbx
AWS_PROJECT_ID=groupings-api
AWS_OWNER=mhodges

# Display name used in script output
PROJECT_NAME="UH Groupings Spring Boot API"

# Network configuration
#
# Only the VPC must already exist. `make aws-setup` creates the two public
# subnets (in different AZs) inside this VPC via aws/cloudformation/vpc.yml
# and passes their IDs to the ECS stack, so no subnet IDs are set here.
# The VPC must provide public internet egress (its main route table routes
# 0.0.0.0/0 to an Internet Gateway).
VPC_ID=vpc-00dc91f881f96e7d0

# ECS configuration
ECS_TASK_COUNT=1

# GitHub and CodePipeline configuration
# For repo https://github.com/hawaii-system-its-ti-iam/uh-groupings-api
#
# GITHUB_CONNECTION_ARN: Create a CodeConnections connection (ProviderType: GitHub)
# in the AWS Console and complete the OAuth handshake. Paste the resulting ARN here.
# The connection is shared across environments; you only need one per AWS account.
GITHUB_ORG=uhawaii-system-its-ti-iam
GITHUB_REPO=uh-groupings-api
GITHUB_BRANCH=dev-mhodges-2203
GITHUB_CONNECTION_ARN=arn:aws:codeconnections:us-west-2:123456789012:connection/xxxxxx